# ==============================================
# Configuration serveur TrouveTaBoite
# Copiez ce fichier vers .env et remplissez les valeurs
# ==============================================

# Mode de l'application
# En LOCAL: development (pas de restrictions CORS)
# En PRODUCTION: production (CORS activé, voir ALLOWED_ORIGINS)
NODE_ENV=development
PORT=5000

# ==============================================
# Base de données PostgreSQL (optionnel)
# ==============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trouvetaboite_db
DB_USER=votre_utilisateur
DB_PASSWORD=votre_mot_de_passe_securise

# ==============================================
# APIs externes
# ==============================================

# API INSEE Sirene (optionnel)
# Obtenir sur: https://api.insee.fr/
INSEE_API_KEY=

# API Pappers (optionnel, pour récupérer les emails)
# Obtenir sur: https://www.pappers.fr/api
PAPPERS_API_TOKEN=

# ==============================================
# Sécurité CORS - IMPORTANT EN PRODUCTION !
# ==============================================
# Liste des origines autorisées (séparées par des virgules)
# Ajoutez votre domaine Vercel et/ou Railway frontend
ALLOWED_ORIGINS=https://trouvetaboite.com,https://www.trouvetaboite.com,https://votre-app.vercel.app,https://votre-app.up.railway.app

# ==============================================
# Variables pour Vercel + Railway (déploiement séparé)
# ==============================================
# URL du backend Railway (à définir dans les env vars Vercel au build time)
# VITE_API_URL=https://votre-backend.up.railway.app

# ==============================================
# Logs
# ==============================================
# Niveau de log: debug, info, warn, error
LOG_LEVEL=info
