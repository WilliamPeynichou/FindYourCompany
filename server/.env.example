# Serveur
PORT=3000
NODE_ENV=production

# Base de données (Railway génère cette URL automatiquement)
DATABASE_URL=mysql://user:password@host:3306/findyourcompany

# API INSEE Sirene — https://api.insee.fr/
INSEE_API_KEY=ta-cle-api-insee

# CORS — domaines autorisés à appeler l'API (séparés par des virgules)
ALLOWED_ORIGINS=https://tondomaine.fr,https://www.tondomaine.fr

# Sécurité
JWT_SECRET=chaine-aleatoire-de-32-caracteres-minimum

# Enrichissement PagesJaunes (0 = désactivé)
ENRICHMENT_LIMIT=0
