# ============================================
# Configuration FindYourCompany - o2switch
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Environnement ---
NODE_ENV=production
PORT=5000

# --- Base de données MySQL (o2switch cPanel) ---
# Trouvable dans cPanel > Bases de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=prefixe_findyourcompany
DB_USER=prefixe_user
DB_PASS=votre_mot_de_passe_db

# --- API INSEE Sirene ---
# Clé API obtenue sur https://api.insee.fr/
INSEE_API_KEY=votre_cle_api_insee

# --- URLs de production ---
# Adapter avec votre nom de domaine
FRONTEND_URL=https://votredomaine.com
API_URL=https://api.votredomaine.com

# --- Enrichissement PagesJaunes (optionnel) ---
ENABLE_ENRICHMENT=false
ENRICHMENT_LIMIT=20

# --- Servir les fichiers statiques depuis le backend (optionnel) ---
# Mettre à true si frontend et backend sont sur le même domaine
SERVE_STATIC=false
STATIC_PATH=/home/USER/public_html
