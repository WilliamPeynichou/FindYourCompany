# Configuration Apache pour TrouveTaBoite
# Compatible O2Switch / cPanel / Passenger
# À placer dans le dossier public_html/trouvetaboite.com/

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # =====================================================
  # Redirection HTTPS (obligatoire pour la sécurité)
  # =====================================================
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # =====================================================
  # Redirection www vers non-www
  # =====================================================
  RewriteCond %{HTTP_HOST} ^www\.trouvetaboite\.com$ [NC]
  RewriteRule ^(.*)$ https://trouvetaboite.com/$1 [R=301,L]

  # =====================================================
  # Proxy vers le backend Node.js (si mod_proxy dispo)
  # Sur O2Switch mutualisé, mod_proxy n'est souvent PAS disponible.
  # Dans ce cas, configurez le Node.js App dans cPanel pour que
  # Passenger route TOUT le trafic vers Express (qui sert aussi le frontend).
  # =====================================================
  <IfModule mod_proxy.c>
    <IfModule mod_proxy_http.c>
      RewriteCond %{REQUEST_URI} ^/api/(.*)$
      RewriteRule ^api/(.*)$ http://127.0.0.1:5000/api/$1 [P,L]
    </IfModule>
  </IfModule>

  # =====================================================
  # React Router - SPA fallback
  # Toutes les autres requêtes vers index.html
  # (Ignoré si Passenger gère le routing via Node.js)
  # =====================================================
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteRule . /index.html [L]
</IfModule>

# =====================================================
# Compression GZIP (améliore les performances)
# =====================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
</IfModule>

# =====================================================
# Cache navigateur (améliore les performances)
# =====================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # Images
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # CSS et JS (Vite ajoute un hash, donc cache long)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Fonts
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  # HTML (pas de cache pour les mises à jour)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# =====================================================
# Headers de sécurité
# =====================================================
<IfModule mod_headers.c>
  # Protection XSS
  Header set X-XSS-Protection "1; mode=block"

  # Empêcher le MIME sniffing
  Header set X-Content-Type-Options "nosniff"

  # Empêcher le clickjacking
  Header set X-Frame-Options "DENY"

  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions Policy
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # Cache pour les assets statiques (avec hash Vite)
  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|gif|webp|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Pas de cache pour HTML (important pour les mises à jour)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# =====================================================
# Bloquer l'accès aux fichiers sensibles
# =====================================================
<FilesMatch "(^\.env|\.git|\.htaccess)">
  Order allow,deny
  Deny from all
</FilesMatch>

# =====================================================
# Types MIME corrects
# =====================================================
<IfModule mod_mime.c>
  AddType image/svg+xml svg svgz
  AddType application/javascript js mjs
  AddType application/json json
  AddType font/woff2 woff2
  AddType font/woff woff
</IfModule>
