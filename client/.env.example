# ============================================
# Configuration Frontend - Production o2switch
# ============================================
# Copier ce fichier en .env.production et remplir les valeurs
# Ces variables sont injectées au moment du BUILD (pas au runtime)

# URL de l'API backend
# Si le backend est sur un sous-domaine : https://api.votredomaine.com
# Si le backend est sur le même domaine (reverse proxy) : laisser vide
VITE_API_URL=https://api.votredomaine.com
